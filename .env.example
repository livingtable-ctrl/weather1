# Kalshi API credentials
# Get these from: kalshi.com/account/profile -> API Keys -> Create New API Key
KALSHI_KEY_ID=your-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Set to "demo" to use the sandbox, "prod" for real money
KALSHI_ENV=demo

# Trading thresholds
MIN_EDGE=0.10
STRONG_EDGE=0.25
MAX_DAILY_LOSS_PCT=0.03
MAX_POSITION_AGE_DAYS=7

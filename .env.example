# Kalshi API credentials
# Get these from: kalshi.com/account/profile -> API Keys -> Create New API Key
KALSHI_KEY_ID=your-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Set to "demo" to use the sandbox, "prod" for real money
KALSHI_ENV=demo

# Trading thresholds
MIN_EDGE=0.10
STRONG_EDGE=0.25
MAX_DAILY_LOSS_PCT=0.03
MAX_POSITION_AGE_DAYS=7

# Position limits (#42, #47)
# MIN_ORDER_COST is hardcoded at $0.05; MAX_SINGLE_TICKER_EXPOSURE is a fraction of starting balance
MAX_SINGLE_TICKER_EXPOSURE=0.10

# Betting strategy (#120): kelly | fixed_pct | fixed_dollars
STRATEGY=kelly
FIXED_BET_PCT=0.01       # used when STRATEGY=fixed_pct
FIXED_BET_DOLLARS=10.0   # used when STRATEGY=fixed_dollars

# Halt trading when balance drops to this fraction of peak. Default 0.20 (20%).
# Previous default was 0.50 — changed 2026-04-18 per code review.
DRAWDOWN_HALT_PCT=0.20

# Logging level (#106): DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=WARNING

# NWS User-Agent (#68): identifies your app to NOAA API
NWS_USER_AGENT=kalshi-weather-predictor/1.0 (user@localhost)

# Pirate Weather API key (fallback when Open-Meteo is unavailable)
# Free tier: 20,000 calls/month — get key at pirateweather.net
PIRATE_WEATHER_API_KEY=

# Discord notifications (optional, #92: comma-separate multiple webhooks)
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_URLS=   # comma-separated for multiple channels

# Notification channels (#123): comma-separated subset of: desktop,pushover,ntfy,discord,email
NOTIFY_CHANNELS=desktop,pushover,ntfy,discord,email

# Email notifications via SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_TO=recipient@email.com
